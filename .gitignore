# =============================================================================
# ICP monorepo .gitignore
# =============================================================================

# --- Node.js / pnpm ----------------------------------------------------------
node_modules/
*.tsbuildinfo
dist/
build/
.turbo/

# --- Next.js -----------------------------------------------------------------
.next/
next-env.d.ts
out/

# --- Python (apps/ai, apps/mcp) ---------------------------------------------
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.venv/
venv/
env/
*.egg-info/
*.egg
.pytest_cache/
.mypy_cache/
.ruff_cache/

# --- Env files ---------------------------------------------------------------
# IMPORTANT: .env.example MUST be committed (template for new contributors).
# Real secrets go in .env (ignored).
.env
.env.local
.env.*.local
.env.key
.env.development
.env.production
!.env.example

# --- Logs --------------------------------------------------------------------
*.log
npm-debug.log*
pnpm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Coverage / test artifacts ----------------------------------------------
coverage/
.nyc_output/
*.lcov

# --- IDE / editor ------------------------------------------------------------
# Default: ignore root .vscode/ for hackathon scope. If team wants shared
# editor config, un-ignore selectively via `!.vscode/extensions.json` etc.
.vscode/
.idea/
*.swp
*.swo
*~

# --- OS ----------------------------------------------------------------------
.DS_Store
Thumbs.db
ehthumbs.db
Desktop.ini

# --- Docker ------------------------------------------------------------------
# Compose override files for local hacking — keep base committed.
docker-compose.override.yml
docker-compose.override.yaml

# --- Auto-generated (S-02 T02) ----------------------------------------------
# OpenAPI codegen output — re-generated via `pnpm openapi:sync` from
# `packages/shared-types/openapi.json`. Per ADR-017 + 08_FE_BE_CONTRACT.md §3.
# NOTE: `openapi.json` IS committed (codegen reproducibility + PR diff review);
# only the generated `src/api/` folder is ignored.
#packages/shared-types/src/api/

# --- Misc temp ---------------------------------------------------------------
*.tmp
*.bak
.cache/

# --- S-04 T01 Vespa CLIP-multilingual binary model files (D-S04-10 LAW) ------
# Generated via `infra/vespa/models/clip_multilingual/EXPORT.md` (optimum-cli);
# distributed by re-export per team member (~3 min one-time), NOT git LFS.
infra/vespa/models/clip_multilingual/model.onnx
#infra/vespa/models/clip_multilingual/tokenizer.json
infra/vespa/models/cross_encoder_rerank/model.onnx
