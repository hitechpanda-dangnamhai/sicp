{
  "openapi": "3.0.0",
  "paths": {
    "/api/v1/health": {
      "get": {
        "operationId": "HealthController_liveness",
        "summary": "Liveness probe",
        "description": "Returns 200 if process is up. No dependency checks.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is alive",
            "content": {
              "application/json": {
                "schema": {
                  "example": {
                    "status": "ok"
                  }
                }
              }
            }
          }
        },
        "tags": [
          "health"
        ]
      }
    },
    "/api/v1/health/ready": {
      "get": {
        "operationId": "HealthController_readiness",
        "summary": "Readiness probe",
        "description": "Returns 200 if all dependencies are reachable. Returns 503 if any dep is down. Dependencies probed: postgres, redis, kafka, otel-collector.",
        "parameters": [],
        "responses": {
          "200": {
            "description": "Service is ready"
          },
          "503": {
            "description": "One or more deps unavailable"
          }
        },
        "tags": [
          "health"
        ]
      }
    }
  },
