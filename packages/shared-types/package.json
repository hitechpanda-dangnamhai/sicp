{
  "name": "@icp/shared-types",
  "version": "0.0.1",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./dto": {
      "types": "./dist/dto/index.d.ts",
      "default": "./dist/dto/index.js"
    },
    "./behavior": {
      "types": "./dist/behavior/index.d.ts",
      "default": "./dist/behavior/index.js"
    },
    "./sse": {
      "types": "./dist/sse/index.d.ts",
      "default": "./dist/sse/index.js"
    },
    "./cart": {
      "types": "./dist/cart.d.ts",
      "default": "./dist/cart.js"
    },
    "./products": {
      "types": "./dist/products.d.ts",
      "default": "./dist/products.js"
    },
    "./recommendations": {
      "types": "./dist/recommendations.d.ts",
      "default": "./dist/recommendations.js"
    },
    "./api": {
      "types": "./dist/api/index.d.ts",
      "default": "./dist/api/index.js"
    }
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "openapi-typescript-codegen": "0.29.0",
    "typescript": "^5.4.0"
  }
}
