/**
 * `clear_confirm` event — Cart clear-all confirmation interrupt UX per
 * D-S05-01/03 LAW Hybrid Routing + Pattern A Interrupt Reuse.
 *
 * Triggered by AI `cart_by_text.py` `cart_clear_confirm` entry intent
 * (dispatched via Gateway POST /intent body field `hint: 'cart_clear_confirm'`
 * per C-S05-F Path α extend hint enum 4→6).
 *
 * Pairs with `status: 'awaiting_user_input'` emitted immediately after. User
 * POSTs `/api/v1/intent/{rid}/action` with `{choice: 'confirm_clear' | 'cancel_clear'}`
 * to resume the graph from interrupt checkpoint.
 *
 * **Per D-S05-09 LAW**: NO `actions[]` field — FE hardcodes button labels
 * "Ở lại giỏ" / "Xoá hết" (clone of `SseVariantDegradedEvent` reject-retry-actions
 * precedent line 219-225). Server doesn't govern label strings.
 *
 * **Per D-S05-10 LAW**: `user_message` BE-driven Rule 6 mockup-locked with
 * embedded numeric substitution (item_count + subtotal). Mockup
 * `intent-05-state-F-clear-confirm.html` line 196 dynamic copy ground truth.
 *
 * Mockup `intent-05-state-F-clear-confirm.html`:
 *   - line 196: "Em sẽ xoá <N> món trị giá <X>₫ khỏi giỏ. Hành động này không thể hoàn tác."
 *   - line 209: AI advice line
 */
export const SseClearConfirmEvent = z.object({
  item_count: z.number().int().nonnegative(),
  subtotal: z.number().int().nonnegative(),
  /** BE-templated full Vietnamese string with embedded item_count + subtotal substitution (D-S05-10 LAW). */
  user_message: z.string(),
  /** BE-templated AI advice line (mockup state-F line 209). */
  advice: z.string(),
});

/**
 * `cart_cleared` event — terminal status emitted after `cart.clear` MCP tool
 * succeeds on resume `choice: 'confirm_clear'` path.
 *
 * **Per D-S05-11 LAW**: minimal trigger payload + FE refetch pattern. FE
 * `useQuery` with `CART_QUERY_KEY` invalidates on event arrival → refetch
 * `GET /cart` → server truth (empty cart) replaces state. Mockup state-B
 * empty cart renders post-refetch.
 *
 * Per `S-05_BRIEF.md` AC7 explicit: "emit cart_cleared SSE → FE refetch shows
 * state-B empty".
 *
 * `.passthrough()` allows forward-compat additive fields (e.g. `cleared_at`)
 * without breaking FE schema validation.
 */
export const SseCartClearedEvent = z.object({}).passthrough();

/**
 * `clear_cancelled` event — emitted on resume `choice: 'cancel_clear'` path.
 *
 * No cart mutation occurred; FE just closes the clear-confirm modal and
 * keeps current cart state unchanged (no refetch needed, but FE may refetch
 * defensively per D-S05-07 LAW optimistic-rollback pattern).
 *
 * Mockup state-F: dismiss action returns to state-0-happy without changes.
 */
export const SseClearCancelledEvent = z.object({}).passthrough();

/**
 * `stock_issue_ready` event — per-item progressive stock replacement per
 * D-S05-04 LAW Stock Replacement via Vespa Similarity + LLM Reason.
 *
 * Emitted PER out-of-stock item as Vespa+LLM lookup completes (progressive
 * streaming mirrors `SseProductReadyEvent` pattern via generic
 * `publish_cart_event` helper). Mockup `intent-05-state-E-stock-issue.html`
 * shimmer skeleton designed for progressive arrival.
 *
 * **Nullable `replacement` + `reason` per D-S05-04 LAW step 4**: if Vespa
 * returns no candidate OR LLM 8s soft-timeout fired (R-S05-2 mitigation),
 * emit with `replacement=null, reason=null`. FE shows only "Bỏ" CTA, no
 * "Thay" option in that case (graceful degrade per D-S04-13 LAW pattern).
 *
 * **C-S05-E resolution path (a)** Phiên Sx05-2-DISCOVER: Vespa+LLM is
 * primary; on null result, fallback to `cart_stock_replacement.json` fixture
 * lookup by category+brand anchor. Replacement candidate still arrives via
 * this event whether sourced live or fixture.
 *
 * Mockup `intent-05-state-E-stock-issue.html`:
 *   - line 282: replacement card title "Tương ớt Chin-su 500g (chai lớn)"
 *   - line 285: available_stock display "còn 47 chai"
 *   - reason chip ≤120 chars Vietnamese per LLM prompt
 */
export const SseStockIssueReadyEvent = z.object({
  product_id: z.string().uuid(),
  replacement: z
    .object({
      product_id: z.string().uuid(),
      title: z.string(),
      brand: z.string(),
      unit_price: z.number().int().nonnegative(),
      available_stock: z.number().int().nonnegative(),
    })
    .nullable(),
  /** LLM-generated 1-line reason ≤120 chars Vietnamese, or null on LLM timeout. */
  reason: z.string().nullable(),
});

/**
 * `stock_issue_summary` event — emitted AFTER all `stock_issue_ready` items
 * have been published, BEFORE the `interrupt('stock_action')` pause.
 *
 * FE uses this as the "all replacement candidates ready" signal to enable
 * the "Bỏ" / "Thay" action UI, then waits for user choice → POSTs
 * `/action` with `choice: 'resolve_remove' | 'resolve_replace'` +
 * `value: {product_id, replacement_id?}` per D-S05-03 LAW.
 *
 * Per D-S05-11 LAW pattern: minimal payload (just out-of-stock product IDs
 * for FE state-machine routing); cart state itself fetched via REST not SSE.
 */
export const SseStockIssueSummaryEvent = z.object({
  out_of_stock_count: z.number().int().positive(),
  product_ids: z.array(z.string().uuid()),
});

/**
 * `cart_updated` event — terminal status emitted after a cart mutation
 * (cart.remove + cart.upsert) on resume `choice: 'resolve_remove'` or
 * `'resolve_replace'` paths.
 *
 * **Per D-S05-11 LAW**: minimal trigger + FE refetch pattern.
 * `queryClient.invalidateQueries({queryKey: CART_QUERY_KEY})` → FE refetch
 * `GET /cart` → server truth replaces local optimistic state.
 *
 * Per `S-05_BRIEF.md` AC6 explicit: "emit cart_updated → FE refetch".
 *
 * Also emitted by Direct REST cart write endpoints (e.g. POST /cart/items)
 * is NOT required — those paths return the updated Cart in the HTTP
 * response body directly per D-S05-01 LAW Hybrid Routing topology.
 */
export const SseCartUpdatedEvent = z.object({}).passthrough();

/**
 * `cart_view_ready` event — terminal happy-path emitted when
 * `cart_view_with_stock_check` entry intent completes with NO out-of-stock
 * items detected.
 *
 * Per D-S05-11 LAW: minimal payload. FE already has cart from initial
 * `GET /cart` REST call (cart page load) — this event just signals "stock
 * validation complete, no replacements needed, you can dismiss any loading
 * spinner / shimmer state".
 *
 * Distinction vs `cart_updated`: `cart_view_ready` = no mutation occurred
 * (stock OK); `cart_updated` = mutation occurred (item removed/replaced).
 */
export const SseCartViewReadyEvent = z.object({}).passthrough();

