 * `interrupt()`). User POSTs `/api/v1/intent/{rid}/action` with
 * `{choice: 'accept'|'reject'}` to resume.
 *
 * Mockup `intent-03B-state-F-typo.html` lines 152-163.
 */
export const SseTypoSuggestionEvent = z.object({
  original: z.string(),
