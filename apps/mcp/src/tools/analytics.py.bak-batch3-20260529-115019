_PERIOD_FMT = {"month": "YYYY-MM", "week": 'IYYY-"W"IW', "day": "YYYY-MM-DD"}


def _anomaly_severity(delta_pct: float) -> str:
    """Classify a period-over-period revenue delta per D-S10-NN-G thresholds."""
    caution = _env_float("ANOMALY_CAUTION_PCT", -15.0)
    opportunity = _env_float("ANOMALY_OPPORTUNITY_PCT", 10.0)
    if delta_pct <= caution:
        return "caution"
    if delta_pct >= opportunity:
        return "opportunity"
    return "normal"


def aggregate(params: dict[str, Any]) -> dict[str, Any]:
    """analytics.aggregate — merchant revenue time series (chart D) + last-30d
    revenue (loan input). Reads analytics_daily (grouped by o.user_id = merchant,
    clean). Feeds Intent 07 chart + suggest_loan avg_monthly_revenue.

    Args:
        params: {
            "merchant_id": str,                 # required (users.id)
            "period": "month"|"week"|"day",     # default "month" (chart granularity)
        }
    Returns: {"period","rows":[{label,revenue,orders,qty}],"last_30d_revenue","_trace"}
    """
    merchant_id = params.get("merchant_id")
    if not isinstance(merchant_id, str) or not merchant_id:
        raise ValueError("'merchant_id' param required (non-empty string)")
    period = params.get("period", "month")
    fmt = _PERIOD_FMT.get(period)
    if fmt is None:
        raise ValueError("'period' must be one of: month, week, day")

    series_sql = (
        "SELECT to_char(day, %(fmt)s) AS label,"
        "       SUM(revenue)::bigint AS revenue,"
        "       SUM(orders_count)    AS orders,"
        "       SUM(items_sold)      AS qty "
        "FROM analytics_daily WHERE merchant_id = %(mid)s "
        "GROUP BY 1 ORDER BY 1"
    )
    last30_sql = (
        "SELECT COALESCE(SUM(revenue),0)::bigint AS r FROM analytics_daily "
        "WHERE merchant_id = %(mid)s AND day > CURRENT_DATE - 30"
    )
    with psycopg.connect(_get_dsn()) as conn:
        with conn.cursor(row_factory=dict_row) as cur:
            cur.execute(series_sql, {"fmt": fmt, "mid": merchant_id})
            rows = [
                {"label": r["label"], "revenue": int(r["revenue"] or 0),
                 "orders": int(r["orders"] or 0), "qty": int(r["qty"] or 0)}
                for r in cur.fetchall()
            ]
            cur.execute(last30_sql, {"mid": merchant_id})
            last30 = int((cur.fetchone() or {}).get("r") or 0)

    _logger.info("analytics.aggregate.done", merchant_id=merchant_id[:8],
                 period=period, periods=len(rows), last_30d=last30)
    return {"period": period, "rows": rows, "last_30d_revenue": last30,
            "_trace": {"merchant_id": merchant_id, "period": period}}


_ANOMALY_SQL = """
SELECT p.category,
  COALESCE(SUM(oi.qty*oi.unit_price) FILTER (WHERE o.created_at::date >  CURRENT_DATE - %(win)s),0) AS recent_rev,
  COALESCE(SUM(oi.qty*oi.unit_price) FILTER (WHERE o.created_at::date <= CURRENT_DATE - %(win)s
                                        AND o.created_at::date >  CURRENT_DATE - %(win2)s),0)      AS prior_rev,
  COALESCE(SUM(oi.qty) FILTER (WHERE o.created_at::date >  CURRENT_DATE - %(win)s),0)              AS recent_qty,
  COALESCE(SUM(oi.qty) FILTER (WHERE o.created_at::date <= CURRENT_DATE - %(win)s
                          AND o.created_at::date >  CURRENT_DATE - %(win2)s),0)                    AS prior_qty
FROM orders o
JOIN order_items oi ON oi.order_id = o.id
JOIN products p     ON p.id = oi.product_id
WHERE o.user_id = %(mid)s AND o.status = 'paid'
  AND o.created_at::date > CURRENT_DATE - %(win2)s
GROUP BY p.category
"""


def detect_anomaly(params: dict[str, Any]) -> dict[str, Any]:
    """analytics.detect_anomaly — period-over-period revenue change per category
    + merchant total, with severity + contribution. Merchant-filtered raw query
    (CS-A). Feeds: suggest_promo (caution delta_pct), explain_trend (recent/prior
    qty+rev -> avg price + category_contribution), restock trigger (opportunity).

    Args:
        params: {
            "merchant_id": str,                 # required
            "window_days": int,                 # default 7 (rolling 7d vs prior 7d)
        }
    Returns: {"merchant":{recent_rev,prior_rev,delta_pct},
              "categories":[{category,recent_rev,prior_rev,recent_qty,prior_qty,
                             delta_pct,contribution_pct,severity}], "_trace"}
    """
    merchant_id = params.get("merchant_id")
    if not isinstance(merchant_id, str) or not merchant_id:
        raise ValueError("'merchant_id' param required (non-empty string)")
    win = int(params.get("window_days", 7))
    if win < 1 or win > 90:
        raise ValueError("'window_days' must be in [1, 90]")

    with psycopg.connect(_get_dsn()) as conn:
        with conn.cursor(row_factory=dict_row) as cur:
            cur.execute(_ANOMALY_SQL, {"mid": merchant_id, "win": win, "win2": win * 2})
            rows = cur.fetchall()

    merch_recent = sum(int(r["recent_rev"]) for r in rows)
    merch_prior = sum(int(r["prior_rev"]) for r in rows)
    merch_delta = merch_recent - merch_prior

    cats = []
    for r in rows:
        rr, pr = int(r["recent_rev"]), int(r["prior_rev"])
        delta_pct = round((rr - pr) / pr * 100, 1) if pr else 0.0
        contribution_pct = round(abs(rr - pr) / abs(merch_delta) * 100) if merch_delta else None
        cats.append({
            "category": r["category"],
            "recent_rev": rr, "prior_rev": pr,
            "recent_qty": int(r["recent_qty"]), "prior_qty": int(r["prior_qty"]),
            "delta_pct": delta_pct,
            "contribution_pct": contribution_pct,
            "severity": _anomaly_severity(delta_pct),
        })
    cats.sort(key=lambda c: c["delta_pct"])  # worst decline first

    merch_delta_pct = round(merch_delta / merch_prior * 100, 1) if merch_prior else 0.0
    _logger.info("analytics.detect_anomaly.done", merchant_id=merchant_id[:8],
                 window_days=win, categories=len(cats), merch_delta_pct=merch_delta_pct)
    return {
        "merchant": {"recent_rev": merch_recent, "prior_rev": merch_prior,
                     "delta_pct": merch_delta_pct},
        "categories": cats,
        "_trace": {"merchant_id": merchant_id, "window_days": win},
    }


_STOCK_SQL = """
SELECT p.id::text AS product_id, p.title, p.category,
       p.stock AS current_stock, p.price AS unit_price,
       COALESCE(SUM(oi.qty) FILTER (WHERE o.created_at::date > CURRENT_DATE - 7),0)  AS qty_7d,
       COALESCE(SUM(oi.qty) FILTER (WHERE o.created_at::date > CURRENT_DATE - 30),0) AS qty_30d
FROM products p
LEFT JOIN order_items oi ON oi.product_id = p.id
LEFT JOIN orders o       ON o.id = oi.order_id
                        AND o.user_id = %(mid)s AND o.status = 'paid'
WHERE p.merchant_id = %(mid)s
  AND (%(category)s::text IS NULL OR p.category = %(category)s::text)
  AND (%(product_id)s::text IS NULL OR p.id::text = %(product_id)s::text)
GROUP BY p.id, p.title, p.category, p.stock, p.price
ORDER BY qty_7d DESC
"""


def stock_snapshot(params: dict[str, Any]) -> dict[str, Any]:
    """analytics.stock_snapshot — per-product stock + velocity (merchant's own
    paid sales, CS-A). Feeds suggest_restock (qty_7d, current_stock) + suggest_loan
    (velocity, unit_price, reorder).

    Args:
        params: {
            "merchant_id": str,           # required
            "category": str | None,       # optional filter
            "product_id": str | None,     # optional filter
        }
    Returns: {"products":[{product_id,title,category,current_stock,unit_price,
              qty_7d,qty_30d,velocity_per_day,days_left}], "_trace"}
    """
    merchant_id = params.get("merchant_id")
    if not isinstance(merchant_id, str) or not merchant_id:
        raise ValueError("'merchant_id' param required (non-empty string)")
    category = params.get("category")
    product_id = params.get("product_id")

    with psycopg.connect(_get_dsn()) as conn:
        with conn.cursor(row_factory=dict_row) as cur:
            cur.execute(_STOCK_SQL, {"mid": merchant_id, "category": category,
                                     "product_id": product_id})
            rows = cur.fetchall()

    products = []
    for r in rows:
        qty_7d = int(r["qty_7d"])
        stock = int(r["current_stock"])
        velocity = round(qty_7d / 7.0, 2)
        days_left = math.floor(stock / velocity) if velocity > 0 else None
        products.append({
            "product_id": r["product_id"], "title": r["title"], "category": r["category"],
            "current_stock": stock, "unit_price": int(r["unit_price"]),
            "qty_7d": qty_7d, "qty_30d": int(r["qty_30d"]),
            "velocity_per_day": velocity, "days_left": days_left,
        })

    _logger.info("analytics.stock_snapshot.done", merchant_id=merchant_id[:8],
                 products=len(products), category=category)
    return {"products": products, "_trace": {"merchant_id": merchant_id,
            "category": category, "product_id": product_id}}


