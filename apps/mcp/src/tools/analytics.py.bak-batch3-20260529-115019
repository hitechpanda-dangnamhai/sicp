def _env_float(name: str, default: float) -> float:
    """Read float from env with safe fallback (S-04 env-tunable precedent)."""
    try:
        return float(os.getenv(name, str(default)))
    except (TypeError, ValueError):
        return default


def _env_int(name: str, default: int) -> int:
    """Read int from env with safe fallback."""
    try:
        return int(os.getenv(name, str(default)))
    except (TypeError, ValueError):
        return default


def _clamp(x: float, lo: float, hi: float) -> float:
    return max(lo, min(hi, x))


def _norm(x: float, full: float) -> float:
    """Normalize x into [0,1] against `full` saturation point (min(x/full, 1))."""
    return min(x / full, 1.0) if full > 0 else 0.0


def _round_to_5k(x: float) -> int:
    """Round VND amount to nearest 5,000 (loan display granularity)."""
    return int(round(x / 5000.0) * 5000)


# ---------------------------------------------------------------------------
# Solver 1 — analytics.suggest_price (Linear Scoring Model, fixed weights)
# ---------------------------------------------------------------------------

def suggest_price(params: dict[str, Any]) -> dict[str, Any]:
    """Math-first price suggestion (Intent 01 + 07). Replaces LLM-guess
    (importing_by_images.py:420) per C-S10-NN-M / D-S10-NN-G.

    PURE: no DB. Caller supplies shopee aggregates + trend trajectory.

    Args:
        params: {
            "shopee_avg_price": int,        # shopee.price_range.aggregates.avg_price
            "shopee_sample_count": int,     # aggregates.sample_count (confidence gate)
            "trend_trajectory": str,        # {"rising","falling","stable"} (gtrends)
            "seller_type": str | None,      # {"premium","standard","budget"} | None
        }

    Returns: {"suggested_price","confidence","emitted","_trace"}.
    Env: PRICE_W_SHOPEE PRICE_W_TREND PRICE_W_SELLER PRICE_TREND_DELTA PRICE_CONF_GATE.
    """
    p_shopee = int(params.get("shopee_avg_price") or 0)
    sample = int(params.get("shopee_sample_count") or 0)
    traj = params.get("trend_trajectory") or "stable"
    seller_type = params.get("seller_type")

    w_shopee = _env_float("PRICE_W_SHOPEE", 1.0)
    w_trend = _env_float("PRICE_W_TREND", 1.0)
    w_seller = _env_float("PRICE_W_SELLER", 1.0)
    delta = _env_float("PRICE_TREND_DELTA", 0.10)
    gate = _env_float("PRICE_CONF_GATE", 0.6)

    trend_factor = delta if traj == "rising" else (-delta if traj == "falling" else 0.0)
    p_trend = p_shopee * (1 + trend_factor)
    seller_factor = {"premium": 1.05, "standard": 1.00, "budget": 0.92}.get(seller_type, 1.00)
    p_seller = p_shopee * seller_factor

    wsum = w_shopee + w_trend + w_seller
    suggested = round((w_shopee * p_shopee + w_trend * p_trend + w_seller * p_seller) / wsum) if wsum else 0
    confidence = sample / (sample + 5) if sample >= 0 else 0.0
    return {
        "suggested_price": int(suggested),
        "confidence": round(confidence, 2),
        "emitted": confidence >= gate,
        "_trace": {
            "P_shopee": p_shopee, "trend_factor": trend_factor, "P_trend": round(p_trend),
            "seller_factor": seller_factor, "P_seller": round(p_seller), "sample_count": sample,
        },
    }


# ---------------------------------------------------------------------------
# Solver 2 — analytics.suggest_promo (elasticity + clamp)
# ---------------------------------------------------------------------------

def suggest_promo(params: dict[str, Any]) -> dict[str, Any]:
    """Math-first promo % (Intent 07 caution; Intent 01 SUGGEST_PROMOTION).
    Replaces hard-code discount_range{5,15}. PURE.

    NOTE: elasticity default 1.2 is a DEMO-ASSUMPTION (human-locked Sx10-C) — seed
    orders carry no price-quantity history to measure real elasticity. Marked in
    `_trace.assumption="demo"`; env-tunable. Upgrade path: per-product elasticity.

    Args: params: {"delta_pct": float}  # revenue drop, e.g. -18.0
    Env: PROMO_ELASTICITY PROMO_MIN_PCT PROMO_MAX_PCT.
    """
    delta_pct = float(params.get("delta_pct") or 0.0)
    elasticity = _env_float("PROMO_ELASTICITY", 1.2)
    lo = _env_float("PROMO_MIN_PCT", 5)
    hi = _env_float("PROMO_MAX_PCT", 20)

    drop_pct = abs(delta_pct)
    promo_pct = _clamp(drop_pct / elasticity, lo, hi) if elasticity else lo
    projected = promo_pct * elasticity
    return {
        "promo_pct": round(promo_pct),
        "projected_recovery_pct": round(projected, 1),
        "emitted": drop_pct > 0,
        "_trace": {"drop_pct": drop_pct, "elasticity": elasticity, "assumption": "demo"},
    }


# ---------------------------------------------------------------------------
# Solver 3 — analytics.suggest_restock (velocity x (cover+lead) x safety - stock)
# ---------------------------------------------------------------------------

def suggest_restock(params: dict[str, Any]) -> dict[str, Any]:
    """Math-first reorder quantity (Intent 07 opportunity; Intent 01
    SUGGEST_STOCK_UP). Replaces trend_delta_pct-only stub. PURE.

    Args: params: {"qty_7d": int, "current_stock": int}
    Env: RESTOCK_LEAD_DAYS RESTOCK_COVER_DAYS RESTOCK_SAFETY.
    """
    qty_7d = int(params.get("qty_7d") or 0)
    current_stock = int(params.get("current_stock") or 0)
    lead = _env_float("RESTOCK_LEAD_DAYS", 3)
    cover = _env_float("RESTOCK_COVER_DAYS", 14)
    safety = _env_float("RESTOCK_SAFETY", 1.5)

    velocity = qty_7d / 7.0
    target_qty = math.ceil(velocity * (cover + lead) * safety)
    reorder_qty = max(0, target_qty - current_stock)
    days_left = math.floor(current_stock / velocity) if velocity > 0 else None
    return {
        "reorder_qty": int(reorder_qty),
        "days_left": days_left,
        "velocity_per_day": round(velocity, 2),
        "emitted": reorder_qty > 0,
        "_trace": {"qty_7d": qty_7d, "target_qty": int(target_qty), "current_stock": current_stock},
    }


# ---------------------------------------------------------------------------
# Solver 4 — analytics.explain_trend (Price-Volume-Mix variance, real data)
# ---------------------------------------------------------------------------

def explain_trend(params: dict[str, Any]) -> dict[str, Any]:
    """Math-first "why up/down" via Price-Volume-Mix decomposition (Intent 07).
    PURE (Option A): receives now/prev qty+price already queried by the SQL tools
    (T01.C) / graph node (T01.D). Identity: volume_effect + price_effect = ΔRevenue.

    trend_score decomposition was REJECTED (vespa-feed.ts: ctr/clicks = random
    noise derived from sold_count, no causal signal) — only qty + unit_price are
    real. Category contribution (G.1) is nullable additive.

    Args:
        params: {
            "qty_now": float, "qty_prev": float,        # units sold, two periods
            "price_now": float, "price_prev": float,    # avg unit_price, two periods
            "delta_rev_category": float | None,         # G.1 numerator (optional)
            "delta_rev_merchant": float | None,         # G.1 denominator (optional)
            "period": str,                              # {"rolling_7d","week","month"}
            "product_id": str | None, "merchant_id": str | None,  # echo for _trace
        }
    Env: TREND_PERIOD_DEFAULT.
    """
    qty_now = float(params.get("qty_now") or 0)
    qty_prev = float(params.get("qty_prev") or 0)
    price_now = float(params.get("price_now") or 0)
    price_prev = float(params.get("price_prev") or 0)
    drev_cat = params.get("delta_rev_category")
    drev_merchant = params.get("delta_rev_merchant")
    period = params.get("period") or os.getenv("TREND_PERIOD_DEFAULT", "rolling_7d")

    rev_prev = qty_prev * price_prev
    rev_now = qty_now * price_now
    delta_rev = rev_now - rev_prev
    volume_effect = (qty_now - qty_prev) * price_prev
    price_effect = (price_now - price_prev) * qty_now
    denom = abs(volume_effect) + abs(price_effect)
    vol_pct = round(abs(volume_effect) / denom * 100) if denom else 0
    price_pct = round(abs(price_effect) / denom * 100) if denom else 0
    top_driver = "volume" if abs(volume_effect) >= abs(price_effect) else "price"
    direction = "down" if delta_rev < 0 else ("up" if delta_rev > 0 else "flat")
    delta_revenue_pct = round(delta_rev / rev_prev * 100, 1) if rev_prev else 0.0

    cat_contrib = None
    if drev_cat is not None and drev_merchant:
        cat_contrib = round(abs(float(drev_cat)) / abs(float(drev_merchant)) * 100)

    dqty = int(qty_now - qty_prev)
    price_chg_pct = round((price_now - price_prev) / price_prev * 100) if price_prev else 0
    return {
        "direction": direction,
        "delta_revenue_pct": delta_revenue_pct,
        "top_driver": top_driver,
        "period": period,
        "category_contribution_pct": cat_contrib,
        "breakdown": [
            {"name": "volume", "pct": vol_pct, "sign": "down" if dqty < 0 else "up",
             "detail": f"sản lượng {'giảm' if dqty < 0 else 'tăng'} {abs(dqty)}"},
            {"name": "price", "pct": price_pct, "sign": "down" if price_chg_pct < 0 else "up",
             "detail": f"giá TB {'giảm' if price_chg_pct < 0 else 'tăng'} {abs(price_chg_pct)}%"},
        ],
        "_trace": {
            "qty_now": int(qty_now), "qty_prev": int(qty_prev),
            "price_now": round(price_now), "price_prev": round(price_prev),
            "rev_now": round(rev_now), "rev_prev": round(rev_prev),
            "volume_effect": round(volume_effect), "price_effect": round(price_effect),
            "product_id": params.get("product_id"), "merchant_id": params.get("merchant_id"),
        },
    }


# ---------------------------------------------------------------------------
# Solver 5 — analytics.suggest_loan (rule-gated capital, reuse Solver 3)
# ---------------------------------------------------------------------------

def suggest_loan(params: dict[str, Any]) -> dict[str, Any]:
    """Math-first capital/loan suggestion (Intent 01 + 07). Replaces hard-code
    suggested_amount=5_000_000 per C-S10-NN-N / G.3. PURE.

    Eligibility gate (tenure + revenue + rising trend + velocity>0); amount sized
    from real revenue (0.5x monthly cap) and capital need (reorder x cost). uy tín
    DERIVED from users.created_at tenure + analytics_daily revenue (NO magic column).
    mode "approx_margin" runs with ZERO new field (cost_price optional V011).

    Args:
        params: {
            "avg_monthly_revenue": int, "tenure_months": float,
            "qty_7d": int, "trend_trajectory": str,
            "reorder_qty": int,            # REUSE Solver 3 output
            "cost_price": int | None, "unit_price": int,
        }
    Env: LOAN_TENURE_MIN/FULL LOAN_REV_MIN/FULL LOAN_W_TENURE/REV LOAN_REV_MULTIPLE
         LOAN_DEFAULT_MARGIN LOAN_MIN LOAN_TERM LOAN_CONF_GATE.
    """
    avg_rev = int(params.get("avg_monthly_revenue") or 0)
    tenure = float(params.get("tenure_months") or 0)
    qty_7d = int(params.get("qty_7d") or 0)
    traj = params.get("trend_trajectory") or "stable"
    reorder_qty = int(params.get("reorder_qty") or 0)
    cost_price = params.get("cost_price")
    unit_price = int(params.get("unit_price") or 0)

    tenure_min = _env_float("LOAN_TENURE_MIN", 3)
    tenure_full = _env_float("LOAN_TENURE_FULL", 12)
    rev_min = _env_float("LOAN_REV_MIN", 3_000_000)
    rev_full = _env_float("LOAN_REV_FULL", 30_000_000)
    w_tenure = _env_float("LOAN_W_TENURE", 0.4)
    w_rev = _env_float("LOAN_W_REV", 0.6)
    rev_multiple = _env_float("LOAN_REV_MULTIPLE", 0.5)
    margin = _env_float("LOAN_DEFAULT_MARGIN", 0.25)
    loan_min = _env_float("LOAN_MIN", 1_000_000)
    term = _env_int("LOAN_TERM", 6)
    gate = _env_float("LOAN_CONF_GATE", 0.6)

    velocity = qty_7d / 7.0
    reputation = _clamp(
        w_tenure * _norm(tenure, tenure_full) + w_rev * _norm(avg_rev, rev_full), 0, 1
    )
    eligible = (
        (tenure >= tenure_min) and (avg_rev >= rev_min)
        and (traj == "rising") and (velocity > 0)
    )

    amount_cap = rev_multiple * avg_rev
    if cost_price:
        capital_need = reorder_qty * int(cost_price)
        mode = "cost_price"
    else:
        capital_need = reorder_qty * round(unit_price * (1 - margin))
        mode = "approx_margin"
    suggested_amount = (
        _round_to_5k(_clamp(capital_need, loan_min, amount_cap))
        if amount_cap >= loan_min else 0
    )
    confidence = reputation
    return {
        "suggested_amount": int(suggested_amount),
        "term_months": term,
        "reputation": round(reputation, 2),
        "confidence": round(confidence, 2),
        "emitted": eligible and confidence >= gate,
        "_trace": {
            "avg_monthly_revenue": avg_rev, "tenure_months": tenure,
            "velocity_per_day": round(velocity, 2), "reorder_qty": reorder_qty,
            "amount_cap": int(amount_cap), "capital_need": int(capital_need),
            "mode": mode, "margin": margin, "eligible": eligible,
        },
    }


# ===========================================================================
# ANALYTICS SQL TOOLS — 3 query tools (S-10 T01.C, additive)
# ===========================================================================
# Per D-S10-NN-D LAW: analytics.aggregate (sales_by_month) + analytics.detect_anomaly
# + analytics.stock_snapshot (+ reuse co_purchased). Supersedes outdated PHASE_05 §E
# names (sales_by_month/trend_history) — reconciled in T01.J.
#
# CS-A resolution (C-S10-NN-P, verified live DB Phase-2): merchant attribution.
#   analytics_daily groups by o.user_id (= merchant) -> CLEAN for merchant totals.
#   analytics_daily_category groups by p.merchant_id -> over-counts OTHER buyers'
#   purchases of the merchant's products (leak: e.g. tuong_ot from S-09 orders).
#   => category-level tools query RAW order_items JOIN orders WHERE o.user_id =
#      merchant (merchant's own paid orders), consistent with analytics_daily.
#
# Rolling windows use DATE-based comparison (o.created_at::date vs CURRENT_DATE),
# matching analytics_daily (mat view keyed by DATE) — clean day boundaries (a
