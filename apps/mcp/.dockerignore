# =============================================================================
# apps/mcp/.dockerignore — T04
# =============================================================================
# Exclude noise from Docker build context to minimize image size + cache thrash.
# Mirror apps/ai/.dockerignore pattern (T03 precedent Phiên 24).
# =============================================================================

# Python build/runtime artifacts
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
build/
develop-eggs/
dist/
downloads/
eggs/
.eggs/
*.egg-info/
*.egg

# Virtual envs (host-side; container uses system Python)
.venv/
venv/
env/
ENV/

# Test/lint caches
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/
.tox/

# IDE / OS
.vscode/
.idea/
*.swp
.DS_Store

# VCS
.git/
.gitignore

# Output artifacts (T04 reports/reviews not needed in image)
s02-outputs/
