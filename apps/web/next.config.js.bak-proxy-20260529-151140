//           policy: promotion from S-02 / Phase 06 defer to current slice).
//
// Source:   slices/S-00b_EXECUTION_GUIDE.md Section 4.8 lines 2530-2536.
//
// Decisions:
// - D-03 LOCKED  — Next.js 14.2.x pin (avoid Next 15 + React 19 breaking changes).
// - `output: 'standalone'` REQUIRED — produces self-contained server.js +
//   minimal node_modules under .next/standalone, consumed by multi-stage
//   Dockerfile (`apps/web/Dockerfile` runner stage). Without this, Dockerfile
//   `node apps/web/server.js` would not exist.
// - **C-NN-T05-NEW-6 RESOLVED-INLINE Phiên N+3** — `rewrites()` proxy
//   `/api/v1/:path*` → `${NEXT_PUBLIC_GATEWAY_URL}/api/v1/:path*`. Required for
//   tracker SDK relative-URL fetch (`tracker.ts:55` const `TRACK_ENDPOINT =
//   '/api/v1/track'`). Without this, FE fetch resolves to `localhost:3000/api/v1/*`
//   → 404. Pattern: same-origin proxy keeps cookies + avoids CORS preflight.
//   Bug latent S-02 T06 ship (tracker emit shipped without proxy); surfaced
//   by S-03 T05 Bước 4 Check 5 DB verify (0 rows for `nav.*` events).
//
// Deferred to Phase 06 (NOT touched in T05):
// - images.domains / images.remotePatterns
// - headers() / redirects()
// - i18n config (Vietnamese-only locale already in app/layout.tsx `lang="vi"`)
// - env exposure (NEXT_PUBLIC_* already loaded via .env.example at runtime)
// - experimental.serverActions (S-02 may enable for form-heavy intents)
// =============================================================================

/** @type {import('next').NextConfig} */
const nextConfig = {
  eslint: { ignoreDuringBuilds: true },
  typescript: { ignoreBuildErrors: false },
  output: 'standalone',
  reactStrictMode: true,
  async rewrites() {
    // Gateway base URL — env-driven for prod override, defaults to dev port.
    const gatewayUrl = process.env.NEXT_PUBLIC_GATEWAY_URL || 'http://localhost:3001';
    return [
      {
        // Same-origin proxy for all Gateway endpoints. Tracker SDK uses
        // `/api/v1/track` (relative); OpenAPI codegen uses absolute via
        // OpenAPI.BASE (T03b QueryProvider config). Both work after this.
        source: '/api/v1/:path*',
        destination: `${gatewayUrl}/api/v1/:path*`,
      },
    ];
  },
};

module.exports = nextConfig;
