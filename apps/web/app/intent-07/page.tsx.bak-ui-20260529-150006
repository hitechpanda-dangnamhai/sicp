// === action card render (by discriminated type) ============================
function renderCard(
  card: AnalyticsCard,
  index: number,
  dispatch: ReturnType<typeof useAnalyzeStream>['dispatch'],
) {
  const dismiss = () => dispatch({ type: 'dismiss_card', index });

  if (card.type === 'caution') {
    const promoPct = card.reasoning.promo?.promo_pct;
    const trend = card.reasoning.trend;
    return (
      <ActionCard variant="wait">
        <CardHeader icon="🏷️" tag="GIẢM TREND" tagTone="amber" title={(card.category ?? '').toUpperCase()}>
          <DeltaBadge pct={card.delta_pct} />
        </CardHeader>
        <p className="text-[12.5px] text-rose-900/90 mt-1.5">{card.rationale}</p>
        <DetailRows
          rows={[
            trend ? { label: 'Biến động doanh thu', value: `${trend.delta_revenue_pct}%`, down: trend.direction === 'down' } : null,
            trend?.top_driver ? { label: 'Nguyên nhân chính', value: trend.top_driver === 'volume' ? 'Sản lượng' : 'Giá bán' } : null,
            trend?.category_contribution_pct != null
              ? { label: 'Đóng góp mức giảm', value: `${trend.category_contribution_pct}%` }
              : null,
          ]}
        />
        <CardActions
          primary={promoPct != null ? `Tạo khuyến mãi -${promoPct}%` : 'Tạo khuyến mãi'}
          onPrimary={dismiss}
          onDismiss={dismiss}
        />
      </ActionCard>
    );
  }

  if (card.type === 'opportunity') {
    const r = card.reasoning.restock;
    return (
      <ActionCard variant="stock-up">
        <CardHeader icon="📈" tag="ĐANG TRENDING" tagTone="green" title={(card.title ?? card.category ?? '').toUpperCase()} />
        <p className="text-[12.5px] text-rose-900/90 mt-1.5">{card.rationale}</p>
        <DetailRows
          rows={[
            { label: 'Nên đặt thêm', value: `${r.reorder_qty}` },
            r.days_left != null ? { label: 'Còn đủ bán', value: `${r.days_left} ngày` } : null,
            { label: 'Tốc độ bán', value: `${r.velocity_per_day}/ngày` },
          ]}
        />
        <CardActions primary={`Đặt thêm ${r.reorder_qty}`} onPrimary={dismiss} onDismiss={dismiss} />
      </ActionCard>
    );
  }

  // H-Q1: loan card — NO mockup yet (Rule-6 ratify pending). Isolated block;
  // delete this branch to suppress until a mockup exists.
  if (card.type === 'loan') {
    const l = card.reasoning.loan;
    return (
      <ActionCard variant="insight">
        <CardHeader icon="💰" tag="VAY VỐN" tagTone="pink" title="VỐN NHẬP HÀNG" />
        <p className="text-[12.5px] text-rose-900/90 mt-1.5">{card.rationale}</p>
        <DetailRows
          rows={[
            { label: 'Hạn mức gợi ý', value: fmtVnd(l.suggested_amount) },
            { label: 'Kỳ hạn', value: `${l.term_months} tháng` },
            { label: 'Điểm uy tín', value: `${Math.round((l.reputation ?? 0) * 100)}/100` },
          ]}
        />
        <CardActions primary="Tìm hiểu vay" onPrimary={dismiss} onDismiss={dismiss} />
      </ActionCard>
    );
  }

  return null;
}

function CardHeader({
  icon,
  tag,
  tagTone,
  title,
  children,
}: {
  icon: string;
  tag: string;
  tagTone: 'amber' | 'green' | 'pink';
  title: string;
  children?: React.ReactNode;
}) {
  const tone =
    tagTone === 'amber'
      ? 'bg-amber-100 text-amber-700'
      : tagTone === 'green'
        ? 'bg-emerald-100 text-emerald-700'
        : 'bg-pink-100 text-pink-700';
  return (
    <div className="flex items-center justify-between gap-2">
      <div className="flex items-center gap-2 min-w-0">
        <span className="text-[18px]" aria-hidden>{icon}</span>
        <div className="min-w-0">
          <span className={`inline-block text-[9px] font-bold tracking-wider px-1.5 py-0.5 rounded ${tone}`}>{tag}</span>
          <p className="text-[13px] font-extrabold text-rose-900 truncate">{title}</p>
        </div>
      </div>
      {children}
    </div>
  );
}

function DeltaBadge({ pct }: { pct: number }) {
  const down = pct < 0;
  return (
    <span className={`text-[12px] font-bold ${down ? 'text-rose-600' : 'text-emerald-600'}`}>
      {down ? '↓' : '↑'}{Math.abs(pct)}%
    </span>
  );
}

type DetailRow = { label: string; value: string; down?: boolean } | null;
function DetailRows({ rows }: { rows: DetailRow[] }) {
  const visible = rows.filter((r): r is NonNullable<DetailRow> => r !== null);
  if (visible.length === 0) return null;
  return (
    <div className="mt-2.5 flex flex-col gap-1 border-t border-pink-100/70 pt-2">
      {visible.map((r) => (
        <div key={r.label} className="flex items-center justify-between">
          <span className="text-[11.5px] text-rose-500">{r.label}</span>
          <span className={`text-[12px] font-semibold ${r.down ? 'text-rose-600' : 'text-rose-900'}`}>{r.value}</span>
        </div>
      ))}
    </div>
  );
}

function CardActions({
  primary,
  onPrimary,
  onDismiss,
}: {
  primary: string;
  onPrimary: () => void;
  onDismiss: () => void;
}) {
  return (
    <div className="flex items-center gap-2 mt-3">
      <button
