// --- helpers ---------------------------------------------------------------
const vnd = new Intl.NumberFormat('vi-VN');
function fmtVnd(n: number): string {
  return `${vnd.format(Math.round(n))}đ`;
}
function fmtShort(n: number): string {
  if (n >= 1_000_000) return `${(n / 1_000_000).toFixed(1).replace('.0', '')}tr`;
  if (n >= 1_000) return `${Math.round(n / 1_000)}K`;
  return `${n}`;
}
function fmtTimer(ms: number): string {
  const s = Math.floor(ms / 1000);
  return `${Math.floor(s / 60)}:${String(s % 60).padStart(2, '0')}`;
}

const PHASE_LABELS: Record<0 | 1 | 2 | 3, string> = {
  0: 'Chuyển giọng nói → văn bản',
  1: 'Hiểu ý định + chọn biểu đồ',
  2: 'Truy vấn dữ liệu doanh thu',
  3: 'Aida soạn lời giải thích',
};

const SUGGESTIONS = [
  { q: 'Doanh thu 7 ngày qua thế nào?', tag: 'LINE · Xu hướng theo ngày' },
  { q: 'So sánh các danh mục bán chạy tháng này', tag: 'BAR · So sánh nhóm hàng' },
  { q: 'Tỷ trọng doanh thu theo danh mục', tag: 'DONUT · Cơ cấu tỷ lệ' },
];

export default function Intent07AnalyzePage() {
  const router = useRouter();
  const stream = useAnalyzeStream();
  const recorder = useVoiceRecorder();
  const lastSubmittedRef = React.useRef<string | null>(null);

  // Recorded audio ready → POST /intent (voice + hint=analyze).
  React.useEffect(() => {
    if (recorder.audioBase64 && recorder.audioBase64 !== lastSubmittedRef.current) {
      lastSubmittedRef.current = recorder.audioBase64;
      void stream.submitUtterance(recorder.audioBase64);
    }
  }, [recorder.audioBase64, stream.submitUtterance]);

  // Recorder (mic permission) error → surface as stream error.
  React.useEffect(() => {
    if (recorder.error) {
      stream.dispatch({ type: 'error', message: 'Không truy cập được micro.', code: recorder.error });
    }
  }, [recorder.error, stream.dispatch]);

  const handleStart = React.useCallback(() => {
    stream.dispatch({ type: 'start_listening' });
    void recorder.start();
  }, [stream, recorder]);

  const handleStop = React.useCallback(() => {
    recorder.stop(); // → audioBase64 effect → submitUtterance
  }, [recorder]);

  const handleCancel = React.useCallback(() => {
    recorder.cancel();
    lastSubmittedRef.current = null;
    stream.dispatch({ type: 'reset' });
  }, [recorder, stream]);

  const { status } = stream.state;

  return (
    <div className="min-h-screen bg-gradient-to-b from-pink-50 via-orange-50/40 to-amber-50/30 flex flex-col">
      {/* Header */}
      <header className="flex items-center justify-between px-4 py-3 border-b border-pink-100/70 bg-white/60 backdrop-blur">
        <button
          onClick={() => router.push('/home')}
          className="text-[13px] text-rose-700 font-medium"
          aria-label="Trang chính"
        >
          ← Trang chính
        </button>
        <div className="flex items-center gap-1.5">
          {status === 'analyzing' || status === 'listening' ? (
            <span className="w-1.5 h-1.5 rounded-full bg-green-500 animate-pulse" aria-hidden />
          ) : null}
          <span className="text-[13px] font-bold text-rose-900">Phân tích kinh doanh</span>
        </div>
        <span className="w-[68px]" aria-hidden />
      </header>

      <main className="flex-1 overflow-y-auto px-4 py-5">
        {status === 'idle' && renderIdle(handleStart)}
        {status === 'listening' &&
          renderListening(recorder.durationMs, handleStop, handleCancel)}
        {status === 'analyzing' && renderAnalyzing(stream.state)}
        {status === 'result' && renderResult(stream.state, stream.dispatch)}
        {status === 'empty' && renderEmpty(handleStart)}
        {status === 'clarify' && renderClarify(stream.state, handleStart)}
        {status === 'error' && renderError(stream.state, handleStart, handleCancel)}
      </main>
    </div>
  );
}

