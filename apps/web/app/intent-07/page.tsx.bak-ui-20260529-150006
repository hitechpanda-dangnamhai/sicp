// === state-C/G: chart (with expand → drilldown) ============================
function renderChart(chart: AnalyzeChartData) {
  if (chart.values.length < 2) return null;
  const total = chart.values.reduce((a, b) => a + b, 0);
  const avg = total / chart.values.length;
  const last = chart.values[chart.values.length - 1];

  const stats = (
    <div className="flex gap-4 pt-2">
      <Stat label="Tổng" value={fmtShort(total)} />
      <Stat label="TB/kỳ" value={fmtShort(avg)} />
      <Stat label="Kỳ gần nhất" value={fmtShort(last)} />
    </div>
  );

  const body =
    chart.type === 'bar' ? (
      <ChartBar
        data={chart.values.map((v, i) => ({ label: chart.labels[i] ?? `${i + 1}`, value: v }))}
        ariaLabel={chart.title}
        accent="pink"
        gradientIdSuffix="i07-analyze"
      />
    ) : (
      // line (default) — pie not emitted by current graph (Rule-7 note).
      <ChartLine
        data={chart.values.map((v, i) => ({ x: i, y: v, label: chart.labels[i] }))}
        ariaLabel={chart.title}
        accent="pink"
        gradientIdSuffix="i07-analyze"
      />
    );

  return (
    <ChartCard
      title={chart.title}
      meta={chart.yAxis}
      live
      stats={stats}
      defaultExpanded={false}
    >
      {body}
    </ChartCard>
  );
}

function Stat({ label, value }: { label: string; value: string }) {
  return (
    <div className="flex flex-col">
      <span className="text-[10px] text-rose-400 font-medium">{label}</span>
      <span className="text-[15px] font-bold text-rose-900">{value}</span>
    </div>
  );
}

