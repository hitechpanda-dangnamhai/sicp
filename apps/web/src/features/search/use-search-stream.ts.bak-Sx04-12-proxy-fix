'use client';

/**
 * apps/web/src/features/search/use-search-stream.ts
 *
 * React hook: state machine + EventSource lifecycle + 17 SSE event handlers
 * for /intent-03 page.
 *
 * Slice:    S-04 First Product Discovery
 * Task:     T05 FE Page Wire (Phiên Sx04-10)
 *
 * Source contract (verified Tier 3 source code):
 *   - `apps/web/lib/sse-client.ts:60-92` — `streamIntent(url, handlers, options)`
 *     typed wrapper; returns close fn.
 *   - `packages/shared-types/src/sse/intent-stream.ts` — 17 event schemas; 10 S-02
 *     base + 7 S-04 NEW (phase_progress, understanding, typo_suggestion,
 *     variant_degraded, co_purchase_hint, empty_state, product_ready).
 *   - `apps/gateway/src/intent/dto/intent-request.dto.ts:35` — mode default
 *     'ai_augmented'.
 *
 * Decisions applied:
 * - D-S04-03 LAW: mode='ai_augmented' on submit; flipped via continue_basic action.
 * - D-S04-13 LAW: Option Z Redis pub/sub — EventSource STAYS OPEN through
 *   interrupt+resume cycles. Close only on `final` event, error, or unmount.
 * - D-S04-14 LAW: 7 SSE handlers route to state machine actions; product_ready
 *   builds carousel per-index slot incrementally.
 * - C-15 'use client': React hooks + EventSource.
 * - D-29 S-03 LAW: StrictMode-safe — useEffect cleanup closes EventSource
 *   on unmount; setState callback pattern (s => reduceState(s, ...)) avoids stale
 *   closures from React 18 double-mount.
 * - W1 LOCK: raw UUID v4 Idempotency-Key (composite built server-side).
 * - W3 LOCK: 5 search.* behavior events WIRED T06 Phiên Sx04-12 (tracking-hooks.ts);
 *            search.first_card_rendered emitted on first product_ready paint per
 *            D-S04-14 LAW (paired with AI ops log intent.first_card_emitted).
 *
 * Public API:
 *   const stream = useSearchStream();
 *   stream.state               — SearchState (read-only)
 *   stream.submitQuery(q, m?)  — POST /intent + open EventSource
 *   stream.dispatch(action)    — escape hatch for retry_ai / continue_basic / etc.
 *   stream.setAddToCartConfirm(item | null)
 *   stream.dismissAddToCartConfirm()
 *   stream.dismissCoPurchaseHint()
 *   stream.setMatchTierFilter(tier)
 */

import { useState, useEffect, useRef, useCallback } from 'react';
import { streamIntent, type IntentStreamHandlers } from '@/lib/sse-client';
import {
  initialState,
  reduceState,
  type SearchAction,
  type SearchState,
  type SearchMode,
  type MatchTierFilter,
  type AddToCartConfirmSummary,
} from './search-state-machine';
import { trackSearchFirstCardRendered } from './tracking-hooks';

export interface UseSearchStreamReturn {
  state: SearchState;
  /** POST /intent + open EventSource. Closes prior stream first if open. */
  submitQuery: (query: string, mode?: SearchMode) => Promise<void>;
  /** Escape hatch for state machine actions (retry_ai / continue_basic / reset / etc.). */
  dispatch: (action: SearchAction) => void;
  setAddToCartConfirm: (item: AddToCartConfirmSummary | null) => void;
  dismissAddToCartConfirm: () => void;
  dismissCoPurchaseHint: () => void;
  setMatchTierFilter: (tier: MatchTierFilter) => void;
}

export function useSearchStream(): UseSearchStreamReturn {
  const [state, setState] = useState<SearchState>(initialState);

  // Refs survive React 18 StrictMode double-mount; cleanup only on real unmount.
  const esCloseRef = useRef<(() => void) | null>(null);

  // ─── D-S04-14 LAW perceived-latency telemetry refs (Phiên Sx04-12 T06) ───
  // submitStartedAtRef: performance.now() at POST /intent dispatch.
  // firstCardEmittedRef: idempotency guard — emit `search.first_card_rendered`
  //   ONCE per request_id (matches AI ops log `intent.first_card_emitted` semantics).
  const submitStartedAtRef = useRef<number | null>(null);
  const firstCardEmittedRef = useRef<boolean>(false);

  const dispatch = useCallback((action: SearchAction) => {
    setState((s) => reduceState(s, action));
  }, []);

  /** Build typed handler map for streamIntent wrapper. */
  const buildHandlers = useCallback(
    (submittedMode: SearchMode, submittedRequestId: string): IntentStreamHandlers => ({
      status: (e) => {
        dispatch({ type: 'status', phase: e.phase });
      },
      phase_progress: (e) => {
        dispatch({ type: 'phase_progress', payload: e });
      },
      understanding: (e) => {
        dispatch({
          type: 'understanding',
          text: e.text,
          highlighted: e.highlighted_terms,
        });
      },
      product_ready: (e) => {
        dispatch({
          type: 'product_ready',
          item: e.item,
          index: e.index,
          total: e.total,
        });
        // D-S04-14 LAW: paired telemetry with AI ops log `intent.first_card_emitted`.
        // Idempotent — first product_ready only. Ref reset on each submitQuery (W3 LOCK).
        if (!firstCardEmittedRef.current && submitStartedAtRef.current !== null) {
          firstCardEmittedRef.current = true;
          const elapsed = Math.round(performance.now() - submitStartedAtRef.current);
          trackSearchFirstCardRendered({
            request_id: submittedRequestId,
            time_to_first_card_ms: elapsed,
            total_cards_expected: e.total,
            mode: submittedMode,
          });
        }
      },
      products: (e) => {
        dispatch({
          type: 'products',
          items: e.items,
          mode: e.mode ?? submittedMode,
        });
      },
      typo_suggestion: (e) => {
        dispatch({ type: 'typo_suggestion', payload: e });
      },
      variant_degraded: (e) => {
        dispatch({ type: 'variant_degraded', payload: e });
      },
      co_purchase_hint: (e) => {
        dispatch({ type: 'co_purchase_hint', payload: e });
      },
      empty_state: (e) => {
        dispatch({ type: 'empty_state', payload: e });
      },
      final: (e) => {
        dispatch({ type: 'final', text: e.text });
        // D-S04-13 LAW: close EventSource on terminal `final` event (graph done).
        // Pattern P2 interrupts keep stream open; only `final` closes.
        esCloseRef.current?.();
        esCloseRef.current = null;
      },
      error: (e) => {
        dispatch({ type: 'error', message: e.message });
      },
    }),
    [dispatch],
  );

  const submitQuery = useCallback(
    async (query: string, mode: SearchMode = 'ai_augmented') => {
      // 1. Close any prior EventSource (new query supersedes).
      esCloseRef.current?.();
      esCloseRef.current = null;

      // 2. POST /api/v1/intent — raw UUID Idempotency-Key (W1 LOCK).
      const idempotencyKey = crypto.randomUUID();
      const res = await fetch('/api/v1/intent', {
        method: 'POST',
        credentials: 'include',
        headers: {
          'Content-Type': 'application/json',
          'Idempotency-Key': idempotencyKey,
        },
        body: JSON.stringify({ modality: 'text', content: query, mode }),
      });

      if (!res.ok) {
        let errText = '';
        try {
          errText = await res.text();
        } catch {
          /* swallow secondary parse error */
        }
        dispatch({
          type: 'error',
          message: `POST /intent failed: HTTP ${res.status}${errText ? ` — ${errText.slice(0, 200)}` : ''}`,
        });
        return;
      }

      const { request_id } = (await res.json()) as { request_id: string };

      // 3. Dispatch submit transition — idle/result → streaming. attemptN preserved.
      dispatch({ type: 'submit', query, requestId: request_id, mode });

      // 4. D-S04-14 LAW: reset first-card telemetry refs for new request_id (Phiên Sx04-12 T06).
      submitStartedAtRef.current = performance.now();
      firstCardEmittedRef.current = false;

      // 5. Open SSE EventSource. Wrapper auto-parses JSON; we dispatch to reducer.
      const close = streamIntent(
        `/api/v1/intent/stream?id=${encodeURIComponent(request_id)}`,
        buildHandlers(mode, request_id),
        {
          onError: () => {
            // Network drop or server close (non-graceful). Reducer sets 'error' kind.
            // Note: EventSource auto-reconnects via heartbeat; we don't dispatch on transient drop.
          },
        },
      );

      esCloseRef.current = close;
    },
    [buildHandlers, dispatch],
  );

  // Cleanup on unmount — D-29 StrictMode-safe.
  // React 18 dev StrictMode mounts → unmounts → remounts. The unmount in the
  // middle WILL close the EventSource we just opened. Two acceptable patterns:
  //   (a) accept the re-open cost in dev (no functional bug — server idempotent on subscribe)
  //   (b) defer EventSource open to user submit (current approach — no open on mount)
  // We use (b): submitQuery opens on demand → StrictMode unmount only matters if
  // user-action-triggered submit happens between the double-mount, which is impossible
  // in single tick. Final unmount cleanup is correct.
  useEffect(() => {
    return () => {
      esCloseRef.current?.();
      esCloseRef.current = null;
    };
  }, []);

  // ─── Public helpers (thin wrappers around dispatch) ──────────────────────

  const setAddToCartConfirm = useCallback(
    (item: AddToCartConfirmSummary | null) => {
      dispatch({ type: 'set_cart_confirm', item });
    },
    [dispatch],
  );

  const dismissAddToCartConfirm = useCallback(() => {
    dispatch({ type: 'dismiss_cart_confirm' });
  }, [dispatch]);

  const dismissCoPurchaseHint = useCallback(() => {
    dispatch({ type: 'dismiss_co_purchase_hint' });
  }, [dispatch]);

  const setMatchTierFilter = useCallback(
    (tier: MatchTierFilter) => {
      dispatch({ type: 'set_match_tier', tier });
    },
    [dispatch],
  );

  return {
    state,
    submitQuery,
    dispatch,
    setAddToCartConfirm,
    dismissAddToCartConfirm,
    dismissCoPurchaseHint,
    setMatchTierFilter,
  };
}
