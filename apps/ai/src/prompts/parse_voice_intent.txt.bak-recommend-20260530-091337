Input utterance: "Cho tôi 2 chai nước tương Maggi"
Voice history: []
Current cart: {{"items": []}}
Output: {{"action": "add", "items": [{{"query": "nước tương Maggi", "qty": 2, "unit": "chai"}}], "confidence": 0.95}}

