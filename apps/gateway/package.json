{
  "name": "@icp/gateway",
  "version": "0.0.1",
  "private": true,
  "description": "ICP API Gateway — NestJS with OTel + Swagger + Idempotency middleware. S-02 T01 emit; T05 +AiClient; T06 +TrackingModule + DatabaseModule. S-03 T02 +AuthModule (bcryptjs + jsonwebtoken + cookie-parser).",
  "main": "dist/main.js",
  "scripts": {
    "dev": "nest start --watch",
    "build": "tsc -p tsconfig.build.json",
    "start": "node dist/main.js",
    "start:prod": "NODE_ENV=production node dist/main.js",
    "lint": "eslint src --ext ts --max-warnings 0",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "openapi:export": "EXPORT_OPENAPI=true node dist/main.js",
    "format": "prettier --write src/**/*.ts"
  },
  "dependencies": {
    "@icp/shared-types": "workspace:*",
    "@nestjs/common": "^10.4.0",
    "@nestjs/config": "^3.2.0",
    "@nestjs/core": "^10.4.0",
    "@nestjs/platform-express": "^10.4.0",
    "@nestjs/swagger": "^7.4.0",
    "@nestjs/throttler": "^6.2.1",
    "@nest-lab/throttler-storage-redis": "^1.0.0",
    "helmet": "^7.1.0",
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/api-logs": "^0.52.1",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.52.1",
    "@opentelemetry/exporter-metrics-otlp-grpc": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/sdk-logs": "^0.52.1",
    "@opentelemetry/sdk-metrics": "1.25.1",
    "@opentelemetry/sdk-node": "0.52.1",
    "@opentelemetry/semantic-conventions": "1.25.1",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "express": "^4.19.2",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "nestjs-zod": "^3.0.0",
    "pg": "^8.13.0",
    "pino": "^9.3.2",
    "reflect-metadata": "^0.2.2",
    "rxjs": "^7.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@nestjs/cli": "^10.4.0",
    "@nestjs/schematics": "^10.1.4",
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.7",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pg": "^8.11.6",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "supertest": "^7.0.0",
    "@types/supertest": "^6.0.2",
    "typescript": "^5.6.2",
    "vitest": "^2.1.0"
  },
  "engines": {
    "node": ">=20.0.0"
  }
}
