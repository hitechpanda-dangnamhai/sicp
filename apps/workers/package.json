{
  "name": "@icp/workers",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/index.js",
  "scripts": {
    "start": "node dist/index.js",
    "start:housekeeper": "tsx src/housekeeper.ts",
    "dev": "tsx watch src/housekeeper.ts",
    "build": "tsc -p tsconfig.build.json",
    "lint": "eslint src --ext ts --max-warnings 0",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:cov": "vitest run --coverage",
    "test:watch": "vitest",
    "seed-shopee": "tsx src/shopee-mock-seed-worker.ts"
  },
  "dependencies": {
    "@opentelemetry/api": "^1.9.0",
    "@opentelemetry/auto-instrumentations-node": "^0.49.0",
    "@opentelemetry/exporter-logs-otlp-grpc": "^0.52.1",
    "@opentelemetry/exporter-trace-otlp-grpc": "^0.52.1",
    "@opentelemetry/resources": "1.25.1",
    "@opentelemetry/sdk-logs": "^0.52.1",
    "@opentelemetry/sdk-node": "0.52.1",
    "@opentelemetry/semantic-conventions": "1.25.1",
    "dotenv": "^16.4.0",
    "ioredis": "^5.4.1",
    "node-cron": "^3.0.3",
    "pg": "^8.11.0",
    "pino": "^9.3.2",
    "tsx": "^4.7.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/node-cron": "^3.0.11",
    "@types/pg": "^8.11.0",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "pino-pretty": "^11.2.2",
    "prettier": "^3.3.3",
    "typescript": "^5.4.0",
    "vitest": "^3.2.6",
    "@vitest/coverage-v8": "^3.2.6"
  }
}
