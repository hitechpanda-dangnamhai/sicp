# ============================================================================
# infra/vespa/schemas/product.sd
# ============================================================================
# ICP product search index schema — Vespa 8.x application package deliverable.
#
# Slice: S-00b Foundation Scaffold, Task T06 Vespa Schema (Phiên 9 LOCKED 2026-05-18).
#
# Source references:
#   - docs/02_DATA_MODEL.md Section 2 (lines 178-275) — structural baseline.
#     Pre-T06 had dim 768 + image_embedding asymmetric HNSW; post-T06 patched
#     to 512 + symmetric per C19 + C20 amendments (decisions-log.md).
#   - docs/07_BEHAVIOR_LOGS.md Section 6.1 (lines 188-237) — 11 behavioral
#     signal fields canonical (impressions/clicks/add_to_cart/purchases/
#     dismissals 7d + impressions/clicks/purchases 30d + ctr_7d/cvr_7d/
#     velocity_score derived).
#   - docs/DECISIONS.md:
#       ADR-024 — Vespa Summary Fields Denormalization (line 239). Drives
#         9 display fields with `summary` indexing (FE Product Card avoids
#         JOIN Postgres post-search).
#       ADR-036 — Image embedding model + dimension (line 472). LOCKED CLIP
#         ViT-B/32 512 dim for both text_embedding + image_embedding
#         (multimodal — text and image cùng vector space).
#
# C8 resolution (S-00b conflict, Phiên 3 LOCKED): ADR-036 (priority 2) wins
# over docs/02_DATA_MODEL.md (priority 5) per Rule 7 hierarchy. T06 uses 512.
# Permanent fix via C19 amendment 2026-05-18 Phiên 9 patches baseline doc
# 768 → 512 in-session (Cách B có giới hạn approved by human).
#
# C12 reminder (Phiên 3 LOCKED Option B): embeddings stored Vespa-only.
# Postgres products table KHÔNG có VECTOR columns (V001 mirror EXACT
# 02_DATA_MODEL Section 1 base DDL). This file là nơi DUY NHẤT embedding
# fields live trong system.
#
# C20 amendment (Phiên 9 LOCKED): image_embedding HNSW block symmetric với
# text_embedding (max-links-per-node: 16, neighbors-to-explore-at-insert:
# 200). Rationale: ADR-036 ratifies image similarity search as Intent 01
# primary use case → cần fast ANN performance parity với text search.
# ============================================================================

schema product {

  document product {

    # === Core identity =====================================================
    field id type string {
      indexing: attribute | summary
    }
    field merchant_id type string {
      indexing: attribute
    }

    # === Searchable text (BM25 + embedding) ================================
    field title type string {
      indexing: index | summary
      index: enable-bm25
    }
    field description type string {
      indexing: index | summary
      index: enable-bm25
    }

    # === Category + structured attrs =======================================
    field category type string {
      indexing: attribute | summary
      attribute: fast-search
    }
    field price type long {
      indexing: attribute | summary
    }
    field stock type int {
      indexing: attribute | summary
    }
    field attributes type map<string, string> {
      # Sx07-F-debug Phiên 2026-05-26 — Add struct-field attribute indexing
      # for chip filter re-search (A1 design). Vespa map<string,string>
      # CANNOT have `attribute` on the map itself; must declare struct-field
      # attribute on `key` + `value` sub-fields. Enables YQL pattern:
      #   attributes contains sameElement(key contains "size", value contains "500ml")
      # See Vespa docs: https://docs.vespa.ai/en/reference/schema-reference.html#type:map
      indexing: summary
      struct-field key   { indexing: attribute }
      struct-field value { indexing: attribute }
    }

    # === Display fields (denormalized per ADR-024) =========================
    # Avoid FE JOIN to Postgres after search — Product Card renders from
    # Vespa response alone. See ADR-024 trade-off analysis.
    field brand type string {
      indexing: attribute | summary
    }
    field image_url type string {
      indexing: summary
    }
    field original_price type long {
      indexing: attribute | summary
    }
    field rating_avg type float {
      indexing: attribute | summary
    }
    field rating_count type int {
      indexing: attribute | summary
    }
    field sold_count type int {
      indexing: attribute | summary
    }
    field image_gradient type string {
      indexing: summary
    }
    field icon_hint type string {
      indexing: summary
    }
    field status type string {
      indexing: attribute
    }

    # === Embeddings — text_embedding is OUTSIDE document block (synthetic) ==
    # text_embedding moved out of document block per Vespa schema validation
    # (Phiên Sx04-2 Bước 4 mid-smoke reality finding): "Indexing expression
    # 'embed clip_multilingual' attempts to modify the value of the document
    # field 'text_embedding'. Use a field outside the document block instead."
    # See synthetic-field declaration AFTER document closing brace below.
    #
    # image_embedding stays IN document block (no embed expression at S-04;
    # fed empty/absent via vespa-feed.ts; S-07 will refactor to synthetic
    # field with image-input embed expression). Kept now as 512-dim
    # placeholder maintaining ADR-036 symmetric HNSW configuration.
    # C20: HNSW symmetric between text_embedding + image_embedding for ANN
    # performance parity (image search = Intent 01 primary use case).
    field image_embedding type tensor<float>(x[512]) {
      indexing: attribute | index
      attribute {
        distance-metric: angular
      }
      index {
        hnsw {
          max-links-per-node: 16
          neighbors-to-explore-at-insert: 200
        }
      }
    }

    # === Trend + temporal ==================================================
    field trend_score type float {
      indexing: attribute | summary
    }
    field created_at type long {
      indexing: attribute
    }

    # === Behavioral signals (per 07_BEHAVIOR_LOGS Section 6.1) =============
    # Updated by aggregator worker every 5min (Phase 05); partial-update on
    # purchase real-time (Phase 04). T06 emits schema only; aggregator
    # worker logic deferred to S-02.
    field impressions_7d type long {
      indexing: attribute | summary
    }
    field clicks_7d type long {
      indexing: attribute | summary
    }
    field add_to_cart_7d type long {
      indexing: attribute | summary
    }
    field purchases_7d type long {
      indexing: attribute | summary
    }
    field dismissals_7d type long {
      indexing: attribute | summary
    }
    field impressions_30d type long {
      indexing: attribute | summary
    }
    field clicks_30d type long {
      indexing: attribute | summary
    }
    field purchases_30d type long {
      indexing: attribute | summary
    }
    field ctr_7d type float {
      indexing: attribute
    }
    field cvr_7d type float {
      indexing: attribute
    }
    field velocity_score type float {
      indexing: attribute
    }
  }

  # === Synthetic embedding fields (OUTSIDE document block per Vespa pattern) ==
  # C8 resolution: ADR-036 overrides 02_DATA_MODEL.md (768 → 512 per C19).
  # C12 Option B: embeddings Vespa-only — V001 Postgres no VECTOR columns.
  # C20: HNSW symmetric between text_embedding + image_embedding for ANN
  # performance parity (image search = Intent 01 primary use case).
  # D-S04-10 LAW (Phiên Sx04-1): text_embedding auto-generated at feed-time
  # by Vespa native `hugging-face-embedder` component `clip_multilingual`
  # (CLIP-ViT-B-32-multilingual-v1, Vietnamese-capable). Indexing expression
  # combines title + description → embed → store. Query-time: YQL
  # `embed(@query, clip_multilingual)` produces 512-dim query vector inside
  # Vespa container (saves 1 RTT — no Python embedding code). Component
  # configured in services.xml. See 02_DATA_MODEL.md §2.1.
  #
  # Vespa pattern (Phiên Sx04-2 Bước 4 mid-smoke reality finding): fields
  # with `embed` indexing expression MUST be declared OUTSIDE document block
  # — they are "synthetic fields" derived from document field inputs; cannot
  # be feed directly (vespa-feed.ts already omits these per D-S04-10 LAW).
  # See https://docs.vespa.ai/en/embedding.html and schemas reference.
  field text_embedding type tensor<float>(x[512]) {
    indexing: input title . " " . input description | embed clip_multilingual | attribute | index
    attribute {
      distance-metric: angular
    }
    index {
      hnsw {
        max-links-per-node: 16
        neighbors-to-explore-at-insert: 200
      }
    }
  }

  # === Cross-encoder pre-tokenized field (Sx07-F-debug Phiên 2026-05-26) ===
  # Per Vespa cross-encoder docs (https://docs.vespa.ai/en/cross-encoders.html):
  # Pre-tokenize (title + description) at feed time using huggingface-tokenizer
  # component `cross_encoder_tokenizer` (services.xml). 256 tokens MAX.
  # Vespa helper functions `tokenInputIds(...)` + `tokenAttentionMask(...)`
  # in rank-profile read this attribute + concat with query tokens.
  field cross_encoder_tokens type tensor<float>(d0[256]) {
    indexing: input title . " " . input description | embed cross_encoder_tokenizer | attribute
  }

  # === Fieldset (schema-level) ==========================================
  # Phiên Sx04-X fix — without `fieldset default { fields: title, description }`,
  # YQL `userQuery()` does not bind tokens to any BM25-indexed field → 0 hits
  # even when title text matches the query. Verified empirically: query="Tam"
  # against title "Nước tương Tam Thái Tử nâu 500ml" returned 0 hits without
  # this fieldset declaration, 1 hit with `model.defaultIndex=title`.
  # fieldset is a schema-level element (peer with rank-profile), NOT a
  # document-body element — Vespa parser rejects it inside `document { ... }`.
  fieldset default {
    fields: title, description
  }

  # === Rank profiles =======================================================
  # S-04 D-S04-03 LAW (Phiên Sx04): Dual rank profiles for Adaptive Single
  # Endpoint + Graceful Degradation architecture. Variant A baseline (BM25
  # only, used when LLM unavailable / mode=basic_fallback) + Variant B
  # ai_augmented (BM25 + vector + trend + match_score summary feature, used
  # when mode=ai_augmented default tier). Hybrid kept as backward-compat
  # alias inheriting ai_augmented (deprecation path; grep verify post-S-04
  # ship before removal).
  # D-S04-10 LAW (Phiên Sx04-1): ai_augmented inputs `query(query_embedding)`
  # — Vespa native embedder produces 512-dim vector via YQL
  # `embed(@query, clip_multilingual)`. See 02_DATA_MODEL.md §2 + §2.1.

  # rank-profile baseline — Variant A fallback (BM25 only, no vector, no trend)
  # Used when LLM unavailable; basic textual relevance.
  rank-profile baseline {
    # Sx07-F-debug Phiên 2026-05-26 — Title weight 3x + phrase proximity boost
    # to fix "exact phrase in title" not ranking above keyword-scattered matches.
    # Previously: bm25(title) + bm25(description) treated equally → query
    # "cholimex hương việt" matched Knorr/Ajinomoto (description has tokens) above
    # actual Cholimex Hương Việt product (exact title match).
    first-phase {
      expression: 3.0 * bm25(title) + bm25(description) + 2.0 * fieldMatch(title).proximity
    }
    summary-features { bm25(title) bm25(description) fieldMatch(title).proximity }
  }

  # rank-profile ai_augmented — Variant B default tier
  # BM25 + closeness(text_embedding) + trend_score; exposes match_score
  # composite via secondPhase summary feature for FE color-coded badge
  # (xanh ≥90% / cam 80-89% / vàng <80% per mockup intent-03B-state-0-happy).
  # `reason` field LLM-generated per-product at LangGraph generate_reasons
  # node — NOT stored in Vespa, emitted via SSE `understanding`/`products`.
  rank-profile ai_augmented {
    # Sx07-F-debug Phiên 2026-05-26 — 3 fixes:
    # 1. Title 3x + phrase proximity → exact title match wins over scattered tokens
    # 2. Tone DOWN vector 0.3 → 0.2 (CLIP semantic too broad: "cholimex hương việt"
    #    semantically matches all VN seasonings → dilutes precision)
    # 3. Tone DOWN trend 0.2 → 0.1 (popular brands Knorr/Ajinomoto dominated;
    #    trend should only break ties, NOT override relevance)
    # Total second-phase: 0.7 BM25 (relevance) + 0.2 vector (recall) + 0.1 trend (tiebreak)
    inputs {
      query(query_embedding) tensor<float>(x[512])
    }
    first-phase {
      expression: 3.0 * bm25(title) + bm25(description) + 2.0 * fieldMatch(title).proximity
    }
    second-phase {
      expression: 0.7 * firstPhase + 0.2 * closeness(field, text_embedding) + 0.1 * attribute(trend_score)
    }
    summary-features { secondPhase bm25(title) bm25(description) closeness(field, text_embedding) fieldMatch(title).proximity }
  }

  # Backward-compat alias for legacy `rank_profile=hybrid` references.
  # Behavior identical to ai_augmented; remove after S-04 ship + grep verify.
  rank-profile hybrid inherits ai_augmented {}

  rank-profile image_similarity {
    inputs {
      query(img_query) tensor<float>(x[512])
    }
    first-phase {
      expression: closeness(field, image_embedding)
    }
  }

  # === ONNX cross-encoder rerank model (Sx07-F-debug Phiên 2026-05-26) ===
  # Per Vespa docs: https://docs.vespa.ai/en/cross-encoders.html
  # Model: cross-encoder/mmarco-mMiniLMv2-L12-H384-v1 (multilingual, 449MB)
  # Inputs: input_ids + attention_mask (computed via tokenInputIds/tokenAttentionMask)
  # Output: logits tensor (d0=batch, d1=score) — relevance score per (query, doc)
  onnx-model cross_encoder_rerank {
    file: models/cross_encoder_rerank/model.onnx
    input input_ids: input_ids
    input attention_mask: attention_mask
    output logits: logits
  }

  # === Cross-encoder rerank profile (Sx07-F-debug Phiên 2026-05-26) ===
  # 3-phase ranking inherits ai_augmented base:
  #   - first-phase: BM25 + phrase proximity (from parent)
  #   - second-phase: BM25 + vector closeness + trend (from parent)
  #   - global-phase: ONNX cross-encoder rerank top 30 (NEW)
  rank-profile cross_encoder_rerank inherits ai_augmented {
    inputs {
      query(query_tokens) tensor<float>(d0[32])
      query(query_embedding) tensor<float>(x[512])
    }
    function input_ids() {
      expression: tokenInputIds(256, query(query_tokens), attribute(cross_encoder_tokens))
    }
    function attention_mask() {
      expression: tokenAttentionMask(256, query(query_tokens), attribute(cross_encoder_tokens))
    }
    function rerank_score() {
      expression: onnx(cross_encoder_rerank).logits{d0:0, d1:0}
    }
    global-phase {
      expression: rerank_score()
      rerank-count: 30
    }
    summary-features {
      rerank_score
      secondPhase
      bm25(title)
      closeness(field, text_embedding)
    }
  }
}
