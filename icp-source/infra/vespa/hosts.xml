<?xml version="1.0" encoding="utf-8" ?>
<!--
  infra/vespa/hosts.xml
  ============================================================================
  Minimal single-host mapping for ICP Vespa dev cluster.

  Slice: S-00b Foundation Scaffold, Task T06 Vespa Schema (Phiên 9 LOCKED).

  Q-1 α resolution (Phiên 9): emit hosts.xml explicit. REST API deploy path
  via deploy.sh does NOT auto-generate hosts.xml (only `vespa` CLI does).
  Without this file, Vespa config server rejects the application package
  because hostalias `node0` (referenced in services.xml) cannot be resolved
  to a physical host.

  Single host `localhost` aliased to `node0` matches the single-node dev
  cluster topology declared in services.xml.
-->
<hosts>
  <host name="localhost">
    <alias>node0</alias>
  </host>
</hosts>
